# Copy to .env and fill in real values. Never commit .env.

# Database — Neon Postgres pooled connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require

# Vercel Blob — read/write token (Vercel dashboard → Storage → Blob)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx

# Auth.js (NextAuth v5) — generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# GA4 Measurement ID (e.g. G-XXXXXXX)
NEXT_PUBLIC_GA_ID=

# Web Push (VAPID) — generate with:  npx web-push generate-vapid-keys --json
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
